APP_ENV=development
API_V1_PREFIX=/api/v1
FRONTEND_URL=http://localhost:5173
FRONTEND_URL_ALT=http://127.0.0.1:5173

API_HOST_PORT=8000

APP_NAME=Advocacia API
APP_VERSION=0.1.0

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=advocacia_db

JWT_SECRET_KEY=your-secret-key
JWT_EXPIRE_MINUTES=60
PASSWORD_RESET_EXPIRE_MINUTES=30

RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev

UPLOAD_DIR=uploads/media
MAX_FILE_SIZE_MB=3
ALLOWED_MIME_TYPES=["image/jpeg","image/png","image/webp","image/gif"]

LEAD_DEDUP_WINDOW_HOURS=1

KANBAN_MAX_PER_COLUMN=100

SCHEDULER_ENABLED=true
DEADLINE_ALERT_CRON=06:00
DEADLINE_ALERT_INTERVALS=30,15,7,3,2,1

# Integração Google Calendar, ver README para o setup.
# Deixe em branco para manter a integração desabilitada.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/integrations/google/callback
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GOOGLE_TOKEN_ENCRYPTION_KEY=