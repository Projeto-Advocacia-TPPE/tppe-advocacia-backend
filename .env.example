APP_ENV=development
API_V1_PREFIX=/api/v1
FRONTEND_URL=http://localhost:5173
FRONTEND_URL_ALT=http://127.0.0.1:5173

API_HOST_PORT=8000

APP_NAME=Advocacia API
APP_VERSION=0.1.0

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=advocacia_db

JWT_SECRET_KEY=your-secret-key
JWT_EXPIRE_MINUTES=60
PASSWORD_RESET_EXPIRE_MINUTES=30

RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev

DATAJUD_API_KEY=cole_a_chave_publica_atual_da_wiki_datajud
DATAJUD_BASE_URL=https://api-publica.datajud.cnj.jus.br
DATAJUD_TIMEOUT_SECONDS=10
DATAJUD_MAX_RETRIES=2
DATAJUD_RETRY_BACKOFF_SECONDS=0.5
DATAJUD_SYNC_INTERVAL_HOURS=6
DATAJUD_SYNC_LIMIT=50
DATAJUD_SYNC_USER_ID=
INTEGRATION_FAILURE_EMAIL_THROTTLE_MINUTES=30

UPLOAD_DIR=uploads/media
MAX_FILE_SIZE_MB=3
ALLOWED_MIME_TYPES=["image/jpeg","image/png","image/webp","image/gif"]

LEAD_DEDUP_WINDOW_HOURS=1

KANBAN_MAX_PER_COLUMN=100

SCHEDULER_ENABLED=true
DEADLINE_ALERT_CRON=06:00
DEADLINE_ALERT_INTERVALS=30,15,7,3,2,1
